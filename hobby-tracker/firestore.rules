rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isResourceOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isRequestOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isUserOwner(userId);
    }

    match /hobbies/{hobbyId} {
      allow read, delete: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner() && isRequestOwner();
    }

    match /sessions/{sessionId} {
      allow read, delete: if isResourceOwner();
      allow create: if isRequestOwner()
        && request.resource.data.hobbyId is string
        && exists(/databases/$(database)/documents/hobbies/$(request.resource.data.hobbyId))
        && get(/databases/$(database)/documents/hobbies/$(request.resource.data.hobbyId)).data.userId == request.auth.uid;
      allow update: if isResourceOwner() && isRequestOwner();
    }
  }
}
